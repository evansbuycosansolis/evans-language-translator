{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "backend": {
      "entrypoint": "server.py",
      "routePrefix": "/backend",
      "framework": "fastapi",
      "includeFiles": [
        "backend/**"
      ]
    }
  }
}
