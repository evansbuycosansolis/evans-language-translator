# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.

# Required: your OpenAI API key
OPENAI_API_KEY=your_openai_api_key_here

# Optional: OpenAI translation model
OPENAI_TRANSLATION_MODEL=gpt-4o-mini

# Backward-compatible fallback used if OPENAI_TRANSLATION_MODEL is not set
OPENAI_MODEL=gpt-4o-mini

# Optional: OpenAI transcription model
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Optional: OpenAI text-to-speech model (default: gpt-4o-mini-tts)
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# Optional: max characters allowed for a single TTS request
MAX_TTS_TEXT_LENGTH=2000

# Optional: max upload size for a single audio request
MAX_AUDIO_FILE_SIZE_BYTES=26214400

# Optional: frontend recording cap in seconds
MAX_RECORDING_SECONDS=30

# Optional: comma-separated list of allowed frontend origins (default shown below)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
